---
import { SITE_TITLE } from '../consts';
const today = new Date();
---

<footer class="bg-[#eaeff1] dark:bg-slate-900/50 mt-20">
	<div class="flex flex-col md:flex-row justify-between items-center px-12 py-16 w-full max-w-screen-2xl mx-auto">
		<div class="mb-8 md:mb-0 text-center md:text-left">
			<span class="font-headline font-bold text-[#2b3437] dark:text-slate-200 block mb-2 text-xl">{SITE_TITLE}</span>
			<p class="font-body text-sm leading-relaxed tracking-wide text-[#5e5f60] dark:text-slate-400">
				&copy; {today.getFullYear()} Intellectual Depth. Technical Precision in Curation.
			</p>
		</div>
		<div class="flex gap-12 font-body text-sm leading-relaxed tracking-wide">
			<div class="flex flex-col gap-3">
				<span class="font-bold text-on-background">Explore</span>
				<a class="text-[#5e5f60] hover:underline underline-offset-4" href="/blog">Blog</a>
				<a class="text-[#5e5f60] hover:underline underline-offset-4" href="/articles">Articles</a>
			</div>
			<div class="flex flex-col gap-3">
				<span class="font-bold text-on-background">Connect</span>
				<a class="text-[#5e5f60] hover:underline underline-offset-4" href="/about">About</a>
				<a class="text-[#5e5f60] hover:underline underline-offset-4" href="https://github.com/lehuydo241937" target="_blank">GitHub</a>
			</div>
		</div>
	</div>
</footer>
