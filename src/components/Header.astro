---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[#f8f9fa]/80 dark:bg-slate-950/80 backdrop-blur-md">
	<nav class="flex justify-between items-center w-full px-12 py-8 max-w-screen-2xl mx-auto">
		<div class="text-2xl font-black tracking-tighter text-[#2b3437] dark:text-slate-50 font-headline">
			<a href="/" class="no-underline">{SITE_TITLE}</a>
		</div>
		<div class="hidden md:flex items-center space-x-8 font-headline font-bold tracking-tight">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="flex items-center space-x-4">
			<button class="scale-95 active:scale-90 transition-transform text-[#485f84] dark:text-[#d5e3ff]">
				<span class="material-symbols-outlined">search</span>
			</button>
		</div>
	</nav>
</header>
