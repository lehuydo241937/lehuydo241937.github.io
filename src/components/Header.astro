---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[#f8f9fa]/90 dark:bg-slate-950/90 backdrop-blur-md border-b border-transparent transition-colors duration-300">
	<nav class="flex justify-between items-center w-full px-6 md:px-12 py-4 md:py-8 max-w-screen-2xl mx-auto">
		<div class="text-xl md:text-2xl font-black tracking-tighter text-[#2b3437] dark:text-slate-50 font-headline z-50 relative">
			<a href="/" class="no-underline">{SITE_TITLE}</a>
		</div>
		
		<div class="hidden md:flex items-center space-x-8 font-headline font-bold tracking-tight">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		
		<div class="flex items-center space-x-2 md:space-x-4 z-50 relative">
			<button class="scale-95 flex items-center justify-center p-2 active:scale-90 transition-transform text-[#485f84] dark:text-[#d5e3ff]">
				<span class="material-symbols-outlined">search</span>
			</button>
			<button id="mobile-menu-btn" class="md:hidden flex items-center justify-center p-2 text-on-surface">
				<span class="material-symbols-outlined" id="mobile-menu-icon" style="font-size: 28px;">menu</span>
			</button>
		</div>
	</nav>

	<!-- Mobile Menu Overlay -->
	<div id="mobile-menu" class="fixed inset-0 bg-[#f8f9fa] dark:bg-slate-950 z-40 hidden flex-col justify-center items-center gap-8 font-headline font-black text-4xl text-on-surface opacity-0 transition-opacity duration-300">
		<a href="/" class="hover:text-primary transition-colors no-underline">Home</a>
		<a href="/blog" class="hover:text-primary transition-colors no-underline">Blog</a>
		<a href="/about" class="hover:text-primary transition-colors no-underline">About</a>
	</div>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
	const btn = document.getElementById('mobile-menu-btn');
	const menu = document.getElementById('mobile-menu');
	const icon = document.getElementById('mobile-menu-icon');

	if (btn && menu && icon) {
		btn.addEventListener('click', () => {
			const isHidden = menu.classList.contains('hidden');
			
			if (isHidden) {
				menu.classList.remove('hidden');
				menu.classList.add('flex');
				// Small delay to allow display block to process before opacity transition
				setTimeout(() => menu.classList.remove('opacity-0'), 10);
				icon.innerText = 'close';
				document.body.style.overflow = 'hidden'; // Prevent scrolling when menu is open
			} else {
				menu.classList.add('opacity-0');
				setTimeout(() => {
					menu.classList.add('hidden');
					menu.classList.remove('flex');
				}, 300); // Wait for fade out
				icon.innerText = 'menu';
				document.body.style.overflow = '';
			}
		});

		// Close menu when a link is clicked
		const links = menu.querySelectorAll('a');
		links.forEach(link => {
			link.addEventListener('click', () => {
				menu.classList.add('opacity-0');
				setTimeout(() => {
					menu.classList.add('hidden');
					menu.classList.remove('flex');
				}, 300);
				icon.innerText = 'menu';
				document.body.style.overflow = '';
			});
		});
	}
  });
</script>
