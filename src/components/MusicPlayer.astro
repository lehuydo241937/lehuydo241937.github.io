---
// To use your own MP3 files:
// 1. Create a folder called 'audio' inside your 'public' folder.
// 2. Drag your .mp3 files into the new 'public/audio' folder.
// 3. Update the URLs below to match (e.g., id: '/audio/my-song.mp3')

const playlists = [
  { name: 'SoundHelix 1', id: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3' },
  { name: 'SoundHelix 2', id: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-2.mp3' },
  { name: 'SoundHelix 3', id: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-3.mp3' }
];
---

<div id="global-music-player" transition:persist="music-player" class="fixed bottom-6 right-6 z-[100] bg-surface-container-highest/80 dark:bg-slate-800/80 backdrop-blur-xl px-2 py-2 rounded-full shadow-lg border border-outline/10 flex items-center gap-2 max-w-[240px]">
  
  <audio id="local-audio-player" loop preload="none">
    <source src={playlists[0].id} type="audio/mpeg">
  </audio>

  <button id="music-toggle" class="text-on-surface hover:text-primary transition-colors flex items-center justify-center w-10 h-10 rounded-full bg-background/50 hover:bg-background shrink-0">
    <span class="material-symbols-outlined text-xl" id="music-icon">play_arrow</span>
  </button>
  
  <div class="flex-1 min-w-0 pr-2">
    <select id="music-playlist-select" class="w-full bg-transparent text-xs font-headline font-bold text-on-surface uppercase tracking-widest outline-none border-none cursor-pointer truncate custom-select appearance-none">
      {playlists.map(p => (
        <option value={p.id}>{p.name}</option>
      ))}
    </select>
  </div>
</div>

<style>
  .custom-select {
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    background-image: url("data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22currentColor%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E");
    background-repeat: no-repeat;
    background-position: right 2px center;
    background-size: 12px;
    padding-right: 16px;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const toggleBtn = document.getElementById('music-toggle');
    const select = document.getElementById('music-playlist-select');
    const icon = document.getElementById('music-icon');
    const audio = document.getElementById('local-audio-player');
    
    if (!toggleBtn || !select || !audio) return;

    if (toggleBtn.hasAttribute('data-initialized')) {
      // Sync the icon state in case View Transitions resets the UI DOM but the audio element kept playing
      if (icon) {
        icon.innerText = !audio.paused ? 'pause' : 'play_arrow';
      }
      return;
    }
    
    toggleBtn.setAttribute('data-initialized', 'true');

    toggleBtn.addEventListener('click', () => {
      if (audio.paused) {
        audio.play().catch(e => console.error("Playback failed:", e));
      } else {
        audio.pause();
      }
    });

    select.addEventListener('change', (e) => {
      const audioUrl = e.target.value;
      audio.src = audioUrl;
      audio.load();
      // Auto-play next track if we were already playing
      if (icon?.innerText === 'pause') {
        audio.play().catch(e => console.error("Playback failed:", e));
      }
    });

    // Automatically update UI icon based on strictly native audio state logic
    audio.addEventListener('play', () => {
      if (icon) icon.innerText = 'pause';
    });

    audio.addEventListener('pause', () => {
      if (icon) icon.innerText = 'play_arrow';
    });
  });
</script>
