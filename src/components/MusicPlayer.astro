---
const playlists = [
  { name: 'Lofi Chill', url: 'https://soundcloud.com/lofi_chill/sets/lofi-chill' },
  { name: 'Car Seat Headrest', url: 'https://soundcloud.com/user-851223646/sets/car-seat-headrest' }
];
---

<div id="global-music-player" transition:persist="music-player" class="fixed bottom-6 right-6 z-[100] bg-surface-container-highest/80 dark:bg-slate-800/80 backdrop-blur-xl px-2 py-2 rounded-full shadow-lg border border-outline/10 flex items-center gap-2 max-w-[240px] font-body">
  
  <!-- Headless SoundCloud Widget -->
  <iframe id="sc-widget" class="fixed -bottom-full opacity-0 pointer-events-none w-1 h-1" allow="autoplay"
          src={`https://w.soundcloud.com/player/?url=${encodeURIComponent(playlists[0].url)}&auto_play=false&hide_related=true&show_comments=false&show_user=false&show_reposts=false&visual=false`}>
  </iframe>

  <button id="music-toggle" class="text-on-surface hover:text-primary transition-colors flex items-center justify-center w-10 h-10 rounded-full bg-background/50 hover:bg-background shrink-0">
    <span class="material-symbols-outlined text-xl" id="music-icon">play_arrow</span>
  </button>
  
  <!-- Custom Drop Up Menu -->
  <div class="relative flex-1 min-w-0 pr-4">
    <button id="playlist-dropdown-btn" class="w-full text-left bg-transparent text-sm text-on-surface outline-none border-none cursor-pointer truncate flex items-center justify-between gap-1 group">
      <span id="current-playlist-name" class="truncate">{playlists[0].name}</span>
      <span class="material-symbols-outlined text-sm text-secondary group-hover:text-primary transition-colors">expand_less</span>
    </button>
    
    <ul id="playlist-dropdown-menu" class="absolute bottom-full right-0 mb-4 w-48 bg-surface-container-highest/90 dark:bg-slate-800/90 backdrop-blur-xl rounded-xl shadow-lg border border-outline/10 hidden flex-col overflow-hidden transition-all origin-bottom z-50">
      {playlists.map(p => (
        <li>
          <button class="playlist-option w-full text-left px-4 py-3 text-sm text-on-surface hover:bg-primary/10 hover:text-primary transition-colors truncate" data-url={p.url} data-name={p.name}>
            {p.name}
          </button>
        </li>
      ))}
    </ul>
  </div>
</div>

<!-- Load the SC Widget API globally -->
<script is:inline src="https://w.soundcloud.com/player/api.js"></script>

<script>
  document.addEventListener('astro:page-load', () => {
    const toggleBtn = document.getElementById('music-toggle');
    const dropdownBtn = document.getElementById('playlist-dropdown-btn');
    const dropdownMenu = document.getElementById('playlist-dropdown-menu');
    const currentNameLabel = document.getElementById('current-playlist-name');
    const icon = document.getElementById('music-icon');
    const iframeElement = document.getElementById('sc-widget');
    const playlistOptions = document.querySelectorAll('.playlist-option');
    
    if (!toggleBtn || !dropdownBtn || !dropdownMenu || !iframeElement) return;

    if (toggleBtn.hasAttribute('data-initialized')) {
      return;
    }
    toggleBtn.setAttribute('data-initialized', 'true');

    // Bulletproof state sync for full page reloads via localStorage
    const savedName = localStorage.getItem('music-player-name');
    if (savedName && currentNameLabel && currentNameLabel.innerText !== savedName) {
      currentNameLabel.innerText = savedName;
    }

    // Toggle dropdown UI
    dropdownBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdownMenu.classList.toggle('hidden');
      dropdownMenu.classList.toggle('flex');
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', (e) => {
      if (!dropdownBtn.contains(e.target as Node) && !dropdownMenu.contains(e.target as Node)) {
        dropdownMenu.classList.add('hidden');
        dropdownMenu.classList.remove('flex');
      }
    });

    // Initialize SoundCloud Widget
    // @ts-ignore
    const widget = SC.Widget(iframeElement);

    widget.bind(SC.Widget.Events.READY, () => {
      
      toggleBtn.addEventListener('click', () => {
        widget.isPaused((paused: boolean) => {
          if (paused) {
            widget.play();
          } else {
            widget.pause();
          }
        });
      });

      playlistOptions.forEach(option => {
        option.addEventListener('click', (e) => {
          const target = e.currentTarget as HTMLElement;
          const url = target.dataset.url;
          const name = target.dataset.name;
          
          if (currentNameLabel && name) {
            currentNameLabel.innerText = name;
            localStorage.setItem('music-player-name', name);
          }
          dropdownMenu.classList.add('hidden');
          dropdownMenu.classList.remove('flex');

          if (url) {
            widget.load(url, { auto_play: true });
            if (icon) icon.innerText = 'pause';
          }
        });
      });

      widget.bind(SC.Widget.Events.PLAY, () => {
        if (icon) icon.innerText = 'pause';
      });

      widget.bind(SC.Widget.Events.PAUSE, () => {
        if (icon) icon.innerText = 'play_arrow';
      });
      
      widget.bind(SC.Widget.Events.FINISH, () => {
        if (icon) icon.innerText = 'play_arrow';
      });
    });
  });
</script>
