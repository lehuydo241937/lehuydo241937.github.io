---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const blogPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Get all unique tags
const allTags = [...new Set(blogPosts.flatMap(post => post.data.tags || []))];

// Determine the top post per tag (sorted by "views" frontmatter, defaulting to pubDate fallback)
const topPostsByTag = allTags.map(tag => {
	const postsWithTag = blogPosts.filter(post => post.data.tags?.includes(tag));
	const topPost = postsWithTag.sort((a, b) => {
		const viewsA = (a.data as any).views || 0;
		const viewsB = (b.data as any).views || 0;
		if (viewsA !== viewsB) return viewsB - viewsA;
		return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
	})[0];
	return { tag, post: topPost };
});

const recentPosts = blogPosts.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-background text-on-background font-body selection:bg-primary-container selection:text-on-primary-container">
		<Header />
		<main class="pt-40">
			<!-- Hero Section -->
			<section class="max-w-screen-2xl mx-auto px-6 md:px-12 mb-20 md:mb-32">
				<div class="editorial-grid">
					<div class="col-span-12 md:col-span-8 lg:col-span-10">
						<span class="font-label text-xs uppercase tracking-[0.2em] text-secondary mb-6 block">Curated Thoughts & Technical Analysis</span>
						<h1 class="font-headline text-4xl md:text-7xl font-extrabold tracking-tighter text-on-background leading-[1.1] mb-6 md:mb-8">
							Exploring the Intersection of <span class="text-primary italic">AI, Games,</span> and <span class="text-primary italic">Data</span>.
						</h1>
						<p class="text-lg md:text-xl text-on-surface-variant max-w-2xl leading-relaxed mb-10">
							A digital editorial dedicated to the technical precision and intellectual depth required to navigate the future of computational systems and immersive experiences.
						</p>
						<div class="flex items-center gap-6">
							<a href={`/blog/${blogPosts[0].id}/`} class="bg-primary text-on-primary px-8 py-4 font-headline font-bold rounded-DEFAULT hover:opacity-90 transition-all no-underline w-full sm:w-auto text-center">
								Read Latest Analysis
							</a>
						</div>
					</div>
				</div>
			</section>

			<!-- Top Posts By Tag Section -->
			{topPostsByTag.length > 0 && (
				<section class="bg-surface-container-low py-20 mb-20 md:mb-32 overflow-hidden">
					<div class="max-w-screen-2xl mx-auto px-6 md:px-12">
						<div class="flex items-end justify-between mb-16">
							<div>
								<span class="font-label text-xs uppercase tracking-[0.2em] text-secondary mb-4 block">Essential Reading</span>
								<h2 class="font-headline text-3xl md:text-5xl font-extrabold tracking-tight text-on-background">Top View of Topic</h2>
							</div>
							<div class="flex items-center gap-3">
								<div id="tag-dots" class="hidden md:flex items-center gap-2 mr-4">
									{topPostsByTag.map((_, i) => (
										<button class="tag-dot w-2 h-2 rounded-full bg-outline/40 transition-all duration-300 hover:bg-primary" data-index={i}></button>
									))}
								</div>
								<button id="tag-prev" class="flex items-center justify-center w-12 h-12 rounded-full border border-outline/20 bg-background/50 hover:bg-primary hover:text-on-primary hover:border-primary transition-all duration-300 text-on-surface">
									<span class="material-symbols-outlined">arrow_back</span>
								</button>
								<button id="tag-next" class="flex items-center justify-center w-12 h-12 rounded-full border border-outline/20 bg-background/50 hover:bg-primary hover:text-on-primary hover:border-primary transition-all duration-300 text-on-surface">
									<span class="material-symbols-outlined">arrow_forward</span>
								</button>
							</div>
						</div>
						
						<div id="tag-slides-container" class="relative">
							{topPostsByTag.map(({ tag, post }, index) => (
								<div class={`tag-slide editorial-grid items-center ${index === 0 ? '' : 'hidden'}`} data-index={index}>
									<div class="col-span-12 lg:col-span-7 relative group cursor-pointer">
										<a href={`/blog/${post.id}/`}>
											<div class="aspect-[16/9] overflow-hidden rounded-lg bg-surface-container shadow-2xl">
												{post.data.heroImage && (
													<img
														src={post.data.heroImage?.src || post.data.heroImage}
														alt={post.data.title}
														class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
													/>
												)}
											</div>
										</a>
									</div>
									<div class="col-span-12 lg:col-span-5 lg:pl-12 mt-10 lg:mt-0">
										<div class="flex items-center gap-4 mb-6">
											<span class="font-label text-[0.65rem] uppercase tracking-widest bg-primary text-on-primary px-3 py-1 rounded-full">{tag}</span>
											{(post.data as any).views !== undefined && (
												<span class="font-label text-[0.65rem] uppercase tracking-widest text-secondary flex items-center gap-1">
													<span class="material-symbols-outlined text-[0.8rem]">visibility</span> {(post.data as any).views} Views
												</span>
											)}
										</div>
										<a href={`/blog/${post.id}/`} class="no-underline">
											<h3 class="font-headline text-3xl md:text-4xl font-extrabold tracking-tight text-on-background mb-6 leading-tight hover:text-primary transition-colors cursor-pointer line-clamp-3">
												{post.data.title}
											</h3>
										</a>
										<p class="text-on-surface-variant text-lg leading-relaxed mb-8 line-clamp-4">
											{post.data.description}
										</p>
										<a class="inline-flex items-center gap-2 font-headline font-bold text-primary group no-underline" href={`/blog/${post.id}/`}>
											Read Perspective
											<span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
										</a>
									</div>
								</div>
							))}
						</div>
					</div>
				</section>
			)}

			<!-- Recent Articles Grid -->
			<section class="max-w-screen-2xl mx-auto px-6 md:px-12 mb-20 md:mb-32">
				<div class="flex flex-col md:flex-row justify-between items-end mb-16">
					<div>
						<h2 class="font-headline text-4xl font-extrabold tracking-tight text-on-background mb-4">Recent Perspectives</h2>
						<p class="text-secondary max-w-md">Technical deep-dives across the three pillars of modern digital evolution.</p>
					</div>
					<div class="hidden md:flex gap-8 font-label text-[0.7rem] uppercase tracking-widest text-secondary">
						<a href="/blog" class="hover:text-primary transition-colors no-underline">All Projects</a>
					</div>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-y-16 gap-x-12">
					{recentPosts.map((post) => (
						<article class="group">
							<a href={`/blog/${post.id}/`} class="no-underline">
								<div class="aspect-[16/9] bg-surface-container overflow-hidden rounded-lg mb-8">
									{post.data.heroImage && (
										<img 
											src={post.data.heroImage?.src || post.data.heroImage} 
											alt={post.data.title} 
											class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
										/>
									)}
								</div>
								<span class="font-label text-[0.65rem] uppercase tracking-widest text-primary mb-4 block">Perspective</span>
								<h3 class="font-headline text-xl font-bold tracking-tight text-on-background group-hover:text-primary transition-colors cursor-pointer mb-4">
									{post.data.title}
								</h3>
								<p class="text-sm text-on-surface-variant leading-relaxed line-clamp-3">
									{post.data.description}
								</p>
							</a>
						</article>
					))}
				</div>
			</section>


		</main>
		<Footer />
		<MusicPlayer />
		<script>
		  document.addEventListener('astro:page-load', () => {
		    const slides = document.querySelectorAll<HTMLElement>('.tag-slide');
		    const dots = document.querySelectorAll<HTMLElement>('.tag-dot');
		    const prevBtn = document.getElementById('tag-prev');
		    const nextBtn = document.getElementById('tag-next');
		    if (!slides.length || !prevBtn || !nextBtn) return;

		    let current = 0;

		    const goTo = (index: number) => {
		      slides[current].classList.add('hidden');
		      dots[current]?.classList.remove('bg-primary', 'w-4');
		      dots[current]?.classList.add('bg-outline/40');
		      current = (index + slides.length) % slides.length;
		      slides[current].classList.remove('hidden');
		      dots[current]?.classList.add('bg-primary', 'w-4');
		      dots[current]?.classList.remove('bg-outline/40');
		    };

		    // Init first dot as active
		    dots[0]?.classList.add('bg-primary', 'w-4');
		    dots[0]?.classList.remove('bg-outline/40');

		    prevBtn.addEventListener('click', () => goTo(current - 1));
		    nextBtn.addEventListener('click', () => goTo(current + 1));
		    dots.forEach(dot => {
		      dot.addEventListener('click', () => goTo(Number(dot.dataset.index)));
		    });
		  });
		</script>
	</body>
</html>
