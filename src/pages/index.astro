---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ProjectStatus from '../components/ProjectStatus.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Exploring the mechanics of virtual worlds.</h1>
				<p>
					Welcome to my research and development blog. Here, I document my journey in game development, 
					computational geometry, and the pursuit of minimalist systems. Currently focusing on procedural 
					generation and immersive ecosystems.
				</p>
			</section>

			<ProjectStatus />

			<section class="recent-thoughts">
				<h2>Recent Thoughts</h2>
				<p>
					You can find my latest research notes and dev logs in the <a href="/blog">blog section</a>. 
					I believe in radical transparency and open-sourcing my failures as much as my successes.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero h1 {
		max-width: 600px;
		margin-bottom: 2.5rem;
	}
	.hero p {
		font-size: 1.25rem;
		opacity: 0.8;
		max-width: 600px;
	}
	section {
		margin-bottom: 4rem;
	}
</style>
