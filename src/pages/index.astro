---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import MusicPlayer from '../components/MusicPlayer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const blogPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredPost = blogPosts[0];
const recentPosts = blogPosts.slice(1, 4);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-background text-on-background font-body selection:bg-primary-container selection:text-on-primary-container">
		<Header />
		<main class="pt-40">
			<!-- Hero Section -->
			<section class="max-w-screen-2xl mx-auto px-12 mb-32">
				<div class="editorial-grid">
					<div class="col-span-12 md:col-span-8 lg:col-span-10">
						<span class="font-label text-xs uppercase tracking-[0.2em] text-secondary mb-6 block">Curated Thoughts & Technical Analysis</span>
						<h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter text-on-background leading-[1.1] mb-8">
							Exploring the Intersection of <span class="text-primary italic">AI, Games,</span> and <span class="text-primary italic">Data</span>.
						</h1>
						<p class="text-lg md:text-xl text-on-surface-variant max-w-2xl leading-relaxed mb-10">
							A digital editorial dedicated to the technical precision and intellectual depth required to navigate the future of computational systems and immersive experiences.
						</p>
						<div class="flex items-center gap-6">
							<a href="/blog" class="bg-primary text-on-primary px-8 py-4 font-headline font-bold rounded-DEFAULT hover:opacity-90 transition-all no-underline">
								Read Latest Analysis
							</a>
							<a class="text-on-surface font-headline font-bold border-b-2 border-primary pb-1 hover:text-primary transition-colors no-underline" href="/blog">
								Explore Archive
							</a>
						</div>
					</div>
				</div>
			</section>

			<!-- Featured Post Section -->
			{featuredPost && (
				<section class="bg-surface-container-low py-32 mb-32">
					<div class="max-w-screen-2xl mx-auto px-12">
						<div class="editorial-grid items-center">
							<div class="col-span-12 lg:col-span-7 relative group cursor-pointer">
								<a href={`/blog/${featuredPost.id}/`}>
									<div class="aspect-[16/9] overflow-hidden rounded-lg bg-surface-container">
										{featuredPost.data.heroImage && (
											<img 
												src={featuredPost.data.heroImage?.src || featuredPost.data.heroImage} 
												alt={featuredPost.data.title} 
												class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" 
											/>
										)}
									</div>
								</a>
							</div>
							<div class="col-span-12 lg:col-span-5 lg:pl-12 mt-8 lg:mt-0">
								<div class="flex items-center gap-4 mb-6">
									<span class="font-label text-[0.65rem] uppercase tracking-widest bg-primary-container text-on-primary-container px-3 py-1 rounded-full">Featured</span>
									<span class="font-label text-[0.65rem] uppercase tracking-widest text-secondary">
										<FormattedDate date={featuredPost.data.pubDate} />
									</span>
								</div>
								<a href={`/blog/${featuredPost.id}/`} class="no-underline">
									<h2 class="font-headline text-3xl md:text-4xl font-extrabold tracking-tight text-on-background mb-6 leading-tight hover:text-primary transition-colors cursor-pointer">
										{featuredPost.data.title}
									</h2>
								</a>
								<p class="text-on-surface-variant leading-relaxed mb-8">
									{featuredPost.data.description}
								</p>
								<a class="inline-flex items-center gap-2 font-headline font-bold text-primary group no-underline" href={`/blog/${featuredPost.id}/`}>
									Full Analysis 
									<span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
								</a>
							</div>
						</div>
					</div>
				</section>
			)}

			<!-- Recent Articles Grid -->
			<section class="max-w-screen-2xl mx-auto px-12 mb-32">
				<div class="flex flex-col md:flex-row justify-between items-end mb-16">
					<div>
						<h2 class="font-headline text-4xl font-extrabold tracking-tight text-on-background mb-4">Recent Perspectives</h2>
						<p class="text-secondary max-w-md">Technical deep-dives across the three pillars of modern digital evolution.</p>
					</div>
					<div class="hidden md:flex gap-8 font-label text-[0.7rem] uppercase tracking-widest text-secondary">
						<a href="/blog" class="hover:text-primary transition-colors no-underline">All Projects</a>
					</div>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-y-16 gap-x-12">
					{recentPosts.map((post) => (
						<article class="group">
							<a href={`/blog/${post.id}/`} class="no-underline">
								<div class="aspect-[16/9] bg-surface-container overflow-hidden rounded-lg mb-8">
									{post.data.heroImage && (
										<img 
											src={post.data.heroImage?.src || post.data.heroImage} 
											alt={post.data.title} 
											class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
										/>
									)}
								</div>
								<span class="font-label text-[0.65rem] uppercase tracking-widest text-primary mb-4 block">Perspective</span>
								<h3 class="font-headline text-xl font-bold tracking-tight text-on-background group-hover:text-primary transition-colors cursor-pointer mb-4">
									{post.data.title}
								</h3>
								<p class="text-sm text-on-surface-variant leading-relaxed line-clamp-3">
									{post.data.description}
								</p>
							</a>
						</article>
					))}
				</div>
			</section>

			<!-- Subscription Form -->
			<section class="max-w-screen-2xl mx-auto px-12 mb-32">
				<div class="bg-surface-container-high rounded-xl p-16 md:p-24 flex flex-col items-center text-center">
					<span class="font-label text-xs uppercase tracking-[0.3em] text-secondary mb-8">Stay Updated</span>
					<h2 class="font-headline text-3xl md:text-5xl font-extrabold tracking-tight text-on-background mb-8 max-w-2xl">
						Join 12,000+ researchers and developers receiving weekly insights.
					</h2>
					<form class="w-full max-w-lg flex flex-col md:flex-row gap-4">
						<input class="flex-1 bg-surface-container-low border-none focus:ring-2 focus:ring-primary text-on-background px-6 py-4 rounded-DEFAULT font-body text-sm placeholder:text-outline-variant" placeholder="Enter your email address" type="email"/>
						<button class="bg-on-background text-surface px-8 py-4 font-headline font-bold rounded-DEFAULT hover:bg-primary transition-all duration-300" type="submit">
							Subscribe
						</button>
					</form>
					<p class="mt-8 text-xs text-secondary tracking-wide">
						No spam. Just technical depth. Unsubscribe at any time.
					</p>
				</div>
			</section>
		</main>
		<Footer />
		<MusicPlayer />
	</body>
</html>
