---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
	const blogPosts = await getCollection('blog');
	const articles = await getCollection('articles');
	const allContent = [...blogPosts, ...articles];
	
	const tags = [...new Set(allContent.map((item) => item.data.tags || []).flat())];
	
	return tags.map((tag) => ({
		params: { tag },
		props: { tag },
	}));
}

const { tag } = Astro.props;
const blogPosts = await getCollection('blog');
const articles = await getCollection('articles');
const allContent = [...blogPosts, ...articles]
	.filter((item) => (item.data.tags || []).includes(tag))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Content tagged with "${tag}" | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-background text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container">
		<Header />
		<main class="pt-40 pb-20 px-6 lg:px-12 max-w-screen-2xl mx-auto">
			<section class="max-w-screen-2xl mx-auto mb-32">
				<div class="flex flex-col md:flex-row justify-between items-end mb-16">
					<div>
						<span class="font-label text-xs uppercase tracking-[0.2em] text-primary mb-2 block">Tag Archive</span>
						<h1 class="font-headline text-5xl font-extrabold tracking-tight text-on-background mb-4">
							#{tag}
						</h1>
						<p class="text-secondary max-w-md">Aggregate perspective on "{tag}" across all collections.</p>
					</div>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-y-16 gap-x-12">
					{
						allContent.map((item) => (
							<article class="group">
								<a href={item.collection === 'blog' ? `/blog/${item.id}/` : `/articles/${item.id}/`} class="no-underline">
									<div class="aspect-[4/5] bg-surface-container overflow-hidden rounded-lg mb-8">
										{item.data.heroImage && (
											<img 
												src={item.data.heroImage?.src || item.data.heroImage} 
												alt={item.data.title} 
												class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
											/>
										)}
									</div>
									<span class="font-label text-[0.65rem] uppercase tracking-widest text-primary mb-4 block">
										{item.collection.slice(0, -1)} <!-- 'blog' or 'article' -->
									</span>
									<h3 class="font-headline text-xl font-bold tracking-tight text-on-background group-hover:text-primary transition-colors cursor-pointer mb-4">
										{item.data.title}
									</h3>
									<p class="text-sm text-on-surface-variant leading-relaxed line-clamp-3">
										{item.data.description}
									</p>
									<p class="text-[10px] uppercase tracking-widest text-secondary mt-4 font-label">
										<FormattedDate date={item.data.pubDate} />
									</p>
								</a>
							</article>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
