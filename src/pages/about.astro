---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-background text-on-surface selection:bg-primary-container selection:text-on-primary-container font-body">
		<Header />
		<main class="pt-32">
			<!-- Hero Section: Asymmetric Editorial Layout -->
			<section class="max-w-screen-2xl mx-auto px-12 py-20 flex flex-col md:grid md:grid-cols-12 gap-16">
				<div class="md:col-span-7 lg:col-span-8 flex flex-col justify-center">
					<span class="text-secondary uppercase tracking-[0.2em] text-[0.7rem] font-medium mb-6">Introduction</span>
					<h1 class="text-5xl md:text-7xl font-headline font-extrabold tracking-tight text-on-surface mb-8 leading-[1.1]">
						Bridging Technical <br/><span class="text-primary italic">Precision</span> & Curiosity.
					</h1>
					<p class="text-lg md:text-xl text-on-surface-variant leading-relaxed max-w-2xl">
						I am a researcher and developer dedicated to the intersection of artificial intelligence, high-fidelity data visualization, and the mechanics of interactive play. My work is defined by a commitment to clarity and a rigorous analytical approach.
					</p>
				</div>
				<div class="md:col-span-5 lg:col-span-4 flex items-center">
					<div class="relative w-full aspect-[4/5] bg-surface-container overflow-hidden group rounded-xl">
						<img 
							alt="Professional Profile" 
							class="w-full h-full object-cover filter grayscale hover:grayscale-0 transition-all duration-700 ease-in-out" 
							src="https://lh3.googleusercontent.com/aida-public/AB6AXuAo64sBtD1xKUub0sfbmUn2wdqyusQ0B8FOw5Lzivjj1S24JUzIShO_aRr4sbyKP2DKkn3z6LkBqAAsA6Imsqw2uGJftCZsjGtkKDaZ62Wit9ikZG7g8BYcrrgkO8mAMS5WbtmatHWwCnTXScPagfcGb-gliI_inCD11QotVBZB-jRRB65wTCtbinaoWvboD9Yyd7Sr6LDeMdHcQ-l8Ema6JoG7VkLR9PZHPtajiWGda1ViuBEOcjvzzSZ4PmIujtFbBpv1iondWmHw"
						/>
						<div class="absolute inset-0 bg-primary/10 mix-blend-multiply opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
					</div>
				</div>
			</section>

			<!-- Biography Content -->
			<section class="bg-surface-container-low">
				<div class="max-w-screen-2xl mx-auto px-12 py-28 flex flex-col md:flex-row gap-20">
					<div class="md:w-1/3">
						<h2 class="text-3xl font-headline font-bold tracking-tight text-on-surface sticky top-40">The Narrative</h2>
					</div>
					<div class="md:w-2/3 space-y-10 text-on-surface-variant text-lg leading-loose">
						<p>
							With over a decade of experience in <span class="text-on-surface font-semibold">computational linguistics</span> and <span class="text-on-surface font-semibold">neural network architectures</span>, my background is rooted in the pursuit of making complex data legible. I believe that technical depth should not be an obstacle to human connection.
						</p>
						<p>
							Beyond the laboratory, my passion lies in the architecture of gaming systems—specifically how procedural generation and data-driven narratives can create emergent experiences. This duality of being a scientist and a creator allows me to approach problems with both structural rigor and creative empathy.
						</p>
						<p>
							Currently, I am focused on the development of ethical AI frameworks that prioritize user agency and transparent data flows, ensuring that the "black box" of machine learning becomes a glass house of understanding.
						</p>
					</div>
				</div>
			</section>

			<!-- Skills Section: Bento Grid -->
			<section class="max-w-screen-2xl mx-auto px-12 py-28">
				<h2 class="text-3xl font-headline font-bold tracking-tight text-on-surface mb-16 text-center">Core Competencies</h2>
				<div class="grid grid-cols-1 md:grid-cols-4 gap-4">
					<!-- AI Research Card -->
					<div class="md:col-span-2 p-10 bg-surface-container-low rounded-xl flex flex-col justify-between min-h-[320px] group hover:bg-white transition-colors border border-transparent hover:border-primary/10">
						<span class="material-symbols-outlined text-4xl text-primary">neurology</span>
						<div>
							<h3 class="text-xl font-headline font-bold text-on-surface mb-2">AI & Machine Learning</h3>
							<p class="text-sm text-secondary leading-relaxed">Specializing in LLM fine-tuning, retrieval-augmented generation (RAG), and neural synthesis.</p>
						</div>
					</div>
					<!-- Data Visualization Card -->
					<div class="p-10 bg-surface-container-low rounded-xl flex flex-col justify-between min-h-[320px] group hover:bg-white transition-colors border border-transparent hover:border-primary/10">
						<span class="material-symbols-outlined text-4xl text-on-surface-variant group-hover:text-primary">query_stats</span>
						<div>
							<h3 class="text-xl font-headline font-bold text-on-surface mb-2">Data Science</h3>
							<p class="text-sm text-secondary leading-relaxed">High-fidelity visualization and statistical modeling.</p>
						</div>
					</div>
					<!-- Gaming Architecture Card -->
					<div class="p-10 bg-surface-container-low rounded-xl flex flex-col justify-between min-h-[320px] group hover:bg-white transition-colors border border-transparent hover:border-primary/10">
						<span class="material-symbols-outlined text-4xl text-on-surface-variant group-hover:text-primary">sports_esports</span>
						<div>
							<h3 class="text-xl font-headline font-bold text-on-surface mb-2">Game Mechanics</h3>
							<p class="text-sm text-secondary leading-relaxed">Systems design and procedural world-building.</p>
						</div>
					</div>
					<!-- Software Engineering -->
					<div class="md:col-span-4 p-12 bg-surface-container rounded-xl flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
						<div class="max-w-md">
							<h3 class="text-2xl font-headline font-bold text-on-surface mb-4">Software Architecture</h3>
							<p class="text-on-surface-variant leading-relaxed">Building resilient, scalable systems using modern functional programming paradigms and distributed cloud infrastructure.</p>
						</div>
						<div class="flex flex-wrap gap-3">
							{['Python', 'Rust', 'TypeScript', 'PyTorch'].map((tech) => (
								<span class="px-4 py-2 bg-background/50 rounded-full text-xs font-bold uppercase tracking-widest text-secondary border border-outline-variant/10">
									{tech}
								</span>
							))}
						</div>
					</div>
				</div>
			</section>

			<!-- Timeline: Vertical Editorial -->
			<section class="bg-surface-container-low/50">
				<div class="max-w-screen-2xl mx-auto px-12 py-28 flex flex-col md:flex-row">
					<div class="md:w-1/3 mb-12 md:mb-0">
						<h2 class="text-3xl font-headline font-bold tracking-tight text-on-surface">Experience</h2>
						<p class="text-secondary mt-4 max-w-xs">A chronological record of professional contributions and academic pursuits.</p>
					</div>
					<div class="md:w-2/3 border-l border-outline-variant/15 pl-12 space-y-20">
						<div class="relative">
							<div class="absolute -left-[53px] top-2 w-2 h-2 rounded-full bg-primary ring-8 ring-background"></div>
							<span class="text-xs font-body font-bold tracking-widest text-primary uppercase">2021 — Present</span>
							<h3 class="text-2xl font-headline font-bold text-on-surface mt-2 mb-4">Senior Research Scientist</h3>
							<p class="text-secondary font-medium italic mb-4">Aether Dynamics Lab</p>
							<p class="text-on-surface-variant max-w-xl">Leading the implementation of privacy-preserving machine learning frameworks and presiding over the neural ethics committee.</p>
						</div>
						<div class="relative">
							<div class="absolute -left-[53px] top-2 w-2 h-2 rounded-full bg-secondary ring-8 ring-background"></div>
							<span class="text-xs font-body font-bold tracking-widest text-secondary uppercase">2018 — 2021</span>
							<h3 class="text-2xl font-headline font-bold text-on-surface mt-2 mb-4">Lead Systems Architect</h3>
							<p class="text-secondary font-medium italic mb-4">Onyx Interactive Studio</p>
							<p class="text-on-surface-variant max-w-xl">Designed the core procedural engine for three award-winning tactical RPG titles, focusing on emergent AI behavior.</p>
						</div>
					</div>
				</div>
			</section>

			<!-- Contact Section -->
			<section class="max-w-screen-2xl mx-auto px-12 py-28">
				<div class="bg-surface-container rounded-3xl p-16 md:p-24 flex flex-col items-center text-center">
					<span class="text-xs font-body font-bold tracking-[0.3em] text-primary uppercase mb-8">Collaboration</span>
					<h2 class="text-4xl md:text-5xl font-headline font-bold tracking-tighter text-on-surface mb-8">Let’s Start a Conversation.</h2>
					<p class="text-on-surface-variant text-lg max-w-2xl mb-12 leading-relaxed">Whether it is about a technical challenge, a creative project, or simply to discuss the future of AI—my inbox is always open for intellectual exchange.</p>
					<form class="flex flex-col md:flex-row gap-6 w-full max-w-lg mb-12">
						<input class="flex-grow bg-background border-none focus:ring-2 focus:ring-primary text-on-surface py-4 px-6 rounded-xl text-sm placeholder:text-secondary shadow-sm" placeholder="Email Address" type="email"/>
						<button class="bg-primary text-on-primary px-10 py-4 font-headline font-bold tracking-tight rounded-xl hover:brightness-110 transition-all shadow-lg">Submit</button>
					</form>
					<div class="flex gap-12 items-center">
						<a class="group flex items-center gap-2 text-secondary hover:text-primary transition-colors no-underline" href="#">
							<span class="material-symbols-outlined text-xl">link</span>
							<span class="font-medium text-sm">LinkedIn</span>
						</a>
						<a class="group flex items-center gap-2 text-secondary hover:text-primary transition-colors no-underline" href="https://github.com/lehuydo241937" target="_blank">
							<span class="material-symbols-outlined text-xl">terminal</span>
							<span class="font-medium text-sm">GitHub</span>
						</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
