---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = (CollectionEntry<'blog'> | CollectionEntry<'articles'>)['data'];

const { title, description, pubDate, updatedDate, heroImage, tags = [] } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.reading-progress-bar {
				height: 2px;
				background-color: #485f84;
				position: fixed;
				top: 0;
				left: 0;
				width: 0%; /* Will be updated via JS if needed */
				z-index: 100;
			}
			.editorial-column {
				max-width: 720px;
			}
		</style>
	</head>

	<body class="bg-background text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container">
		<Header />
		<div class="reading-progress-bar" id="progress-bar"></div>
		
		<main class="pt-40 pb-20 px-6 lg:px-12 max-w-screen-2xl mx-auto flex flex-col lg:flex-row gap-16 justify-center">
			<!-- Article Content Column -->
			<article class="editorial-column w-full mx-auto lg:mx-0">
				<!-- Header Metadata -->
				<header class="mb-16">
					<div class="flex items-center gap-4 mb-6">
						{tags[0] && (
							<span class="px-3 py-1 bg-primary-container text-on-primary-container font-label text-[10px] uppercase tracking-wider rounded-full">
								{tags[0]}
							</span>
						)}
						<span class="text-secondary font-label text-[10px] uppercase tracking-wider">
							<FormattedDate date={pubDate} />
						</span>
					</div>
					<h1 class="text-on-surface font-headline text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.1] mb-8">
						{title}
					</h1>
					<p class="text-secondary text-xl leading-relaxed font-body">
						{description}
					</p>
					{updatedDate && (
						<p class="text-xs italic text-secondary mt-4">
							Last updated on <FormattedDate date={updatedDate} />
						</p>
					)}
				</header>

				<!-- Hero Image -->
				{heroImage && (
					<div class="mb-16">
						<img src={heroImage.src} alt={title} class="w-full h-auto object-cover rounded-xl shadow-xl" />
					</div>
				)}

				<!-- Content -->
				<section class="prose max-w-none">
					<slot />
				</section>

				<!-- Footer / Tags -->
				<footer class="mt-20 pt-12 border-t border-surface-container-high">
					<div class="flex flex-col md:flex-row justify-between items-center gap-8">
						<div class="flex flex-wrap gap-2">
							{tags.map((tag) => (
								<a href={`/tags/${tag}`} class="px-3 py-1 bg-surface-container-high text-secondary font-label text-[10px] uppercase rounded no-underline hover:bg-primary hover:text-on-primary transition-colors">
									#{tag}
								</a>
							))}
						</div>
						<div class="flex items-center gap-6">
							<span class="text-secondary font-label text-[10px] uppercase tracking-widest">Share Context</span>
							<div class="flex gap-4">
								<button class="w-10 h-10 flex items-center justify-center bg-surface-container-low text-primary rounded-full hover:bg-primary hover:text-on-primary transition-all">
									<span class="material-symbols-outlined text-lg">link</span>
								</button>
								<button class="w-10 h-10 flex items-center justify-center bg-surface-container-low text-primary rounded-full hover:bg-primary hover:text-on-primary transition-all">
									<span class="material-symbols-outlined text-lg">share</span>
								</button>
							</div>
						</div>
					</div>
				</footer>
			</article>
		</main>
		<Footer />

		<script>
			// Basic reading progress bar logic
			const progressBar = document.getElementById('progress-bar');
			window.onscroll = function() {
				const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
				const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
				const scrolled = (winScroll / height) * 100;
				if (progressBar) progressBar.style.width = scrolled + "%";
			};
		</script>
	</body>
</html>
